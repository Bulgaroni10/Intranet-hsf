# Referência. O projeto não carrega este arquivo automaticamente.
# Configure estas variáveis no ambiente do serviço NSSM.
GSF_DEBUG=false
GSF_SECRET_KEY=gere-uma-chave-longa-unica-e-secreta
GSF_ALLOWED_HOSTS=intranet.osascohsf.hosp,SRV-INTRANET,SRV-INTRANET.osascohsf.hosp,127.0.0.1
GSF_LOG_DIR=C:\Projetos\intranet_gsf\logs
GSF_LOG_LEVEL=INFO

# Oracle do MV (credenciais de leitura da integração antiga)
GSF_MV_DB_USER=
GSF_MV_DB_PASSWORD=
GSF_MV_DB_DSN=servidor:1521/servico
# Opcional: informe apenas se o servidor Oracle exigir o modo Thick.
GSF_MV_ORACLE_CLIENT_DIR=
